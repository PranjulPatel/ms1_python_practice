import numpy as np
class EmployeePerformanceAnalyzer:
  def create_performance_array(self,scores_array:list)->np.ndarray:
    return np.array(scores_array,dtype=np.int64)

  def validate_scores(self,performance_array:np.ndarray)->bool:
    if performance_array.size==0:
      return False

    if np.any((performance_array<0) | (performance_array>100)):
      return True
    
    return False

  def compute_performance_summary(self,performance_array:np.ndarray)->tuple:
    arr=np.array(performance_array,dtype=np.int)
    Total=np.sum(arr)
    Average=round(float(np.mean(arr)),1)
    Maximum=np.max(arr)

    return (Total,Average,Maximum)

  def apply_bonus(self,performance_array:np.ndarray)->np.ndarray:
    float_arr=performance_array.astype(float)

    mask=float_arr>85
    float_arr[mask]=float_arr[mask]*1.05

    float_arr=np.clip(float_arr,None,100.0)

    return np.round(float_arr,1)

